{
    "openapi": "3.0.0",
    "info": {
        "title": "Transaction Service API",
        "description": "IAE Tugas 2 - Mini Service untuk manajemen transaksi dan cicilan pinjaman",
        "contact": {
            "email": "student@telkomuniversity.ac.id"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Local Server"
        }
    ],
    "paths": {
        "/api/v1/transactions": {
            "get": {
                "tags": [
                    "Transactions"
                ],
                "summary": "Ambil daftar semua transaksi",
                "operationId": "7982071b501714798015d3493437d591",
                "responses": {
                    "200": {
                        "description": "Daftar transaksi berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Data retrieved successfully"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "id": {
                                                        "type": "integer"
                                                    },
                                                    "account_id": {
                                                        "type": "string"
                                                    },
                                                    "type": {
                                                        "type": "string",
                                                        "enum": [
                                                            "credit",
                                                            "debit"
                                                        ]
                                                    },
                                                    "amount": {
                                                        "type": "number"
                                                    },
                                                    "description": {
                                                        "type": "string"
                                                    },
                                                    "reference_number": {
                                                        "type": "string"
                                                    },
                                                    "transaction_date": {
                                                        "type": "string"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        },
                                        "meta": {
                                            "properties": {
                                                "service_name": {
                                                    "type": "string",
                                                    "example": "Transaction-Service"
                                                },
                                                "api_version": {
                                                    "type": "string",
                                                    "example": "v1"
                                                },
                                                "total": {
                                                    "type": "integer"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - X-IAE-KEY tidak valid"
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ]
            }
        },
        "/api/v1/transactions/account/{account_id}": {
            "get": {
                "tags": [
                    "Transactions"
                ],
                "summary": "Ambil riwayat transaksi milik nasabah tertentu",
                "operationId": "dec217ee41dc3788adc9485545fa9192",
                "parameters": [
                    {
                        "name": "account_id",
                        "in": "path",
                        "description": "ID rekening nasabah",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "ACC-001"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Riwayat transaksi nasabah berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Transaksi tidak ditemukan untuk akun ini"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ]
            }
        },
        "/api/v1/transactions/repayment/{account_id}": {
            "get": {
                "tags": [
                    "Repayments"
                ],
                "summary": "Cek riwayat pembayaran cicilan nasabah",
                "operationId": "aeb5df0f50da43d3d4f7b11b1849837a",
                "parameters": [
                    {
                        "name": "account_id",
                        "in": "path",
                        "description": "ID rekening nasabah",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "ACC-001"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Riwayat cicilan berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Data cicilan tidak ditemukan"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ]
            }
        },
        "/api/v1/transactions/repayment": {
            "post": {
                "tags": [
                    "Repayments"
                ],
                "summary": "Eksekusi pembayaran cicilan pinjaman",
                "operationId": "b55abd51a7237a798db2576bc7514af8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "account_id",
                                    "repayment_amount",
                                    "installment_number"
                                ],
                                "properties": {
                                    "account_id": {
                                        "type": "string",
                                        "example": "ACC-001"
                                    },
                                    "repayment_amount": {
                                        "type": "number",
                                        "example": 1500000
                                    },
                                    "installment_number": {
                                        "type": "integer",
                                        "example": 3
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Pembayaran cicilan berhasil dieksekusi",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Repayment processed successfully"
                                        },
                                        "data": {
                                            "type": "object"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Data cicilan tidak ditemukan atau sudah terbayar"
                    },
                    "422": {
                        "description": "Validasi gagal"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "ApiKeyAuth": {
                "type": "apiKey",
                "name": "X-IAE-KEY",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Transactions",
            "description": "Transactions"
        },
        {
            "name": "Repayments",
            "description": "Repayments"
        }
    ]
}